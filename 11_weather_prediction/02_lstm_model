   "source": [
    "# ==================================================\n",
    "# LSTM 第一步：归一化 + 构造监督学习样本\n",
    "# ==================================================\n",
    "print(\"=\" * 60)\n",
    "print(\"  LSTM 第一步：归一化 + 构造监督学习样本\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "\n",
    "# ---------- 1. 数据准备 ----------\n",
    "# 转为二维数组，scaler 需要 (n, 1) 格式\n",
    "train_arr = train.values.reshape(-1, 1)\n",
    "test_arr  = test.values.reshape(-1, 1)\n",
    "\n",
    "print(f\"\\n  训练集样本数：{len(train_arr)}\")\n",
    "print(f\"  测试集样本数：{len(test_arr)}\")\n",
    "\n",
    "# ---------- 2. 归一化 ----------\n",
    "scaler = MinMaxScaler(feature_range=(0, 1))\n",
    "\n",
    "# 只在训练集上 fit，学习极值\n",
    "train_scaled = scaler.fit_transform(train_arr)\n",
    "\n",
    "# 测试集使用训练集的统计量做 transform，不重新 fit\n",
    "test_scaled  = scaler.transform(test_arr)\n",
    "\n",
    "print(f\"\\n  归一化完成（基于训练集统计量）\")\n",
    "print(f\"  训练集最小值：{scaler.data_min_[0]:.2f}°C  →  0.0\")\n",
    "print(f\"  训练集最大值：{scaler.data_max_[0]:.2f}°C  →  1.0\")\n",
    "print(f\"  测试集归一化后范围：[{test_scaled.min():.3f}, {test_scaled.max():.3f}]\")\n",
    "\n",
    "# ---------- 3. 构造监督学习样本 ----------\n",
    "WINDOW = 30   # 用过去30天预测第31天\n",
    "\n",
    "def create_sequences(data, window):\n",
    "    \"\"\"\n",
    "    滑动窗口构造监督学习样本\n",
    "    输入 data: shape (n, 1)\n",
    "    输出 X: shape (样本数, window, 1)\n",
    "         y: shape (样本数,)\n",
    "    \"\"\"\n",
    "    X, y = [], []\n",
    "    for i in range(window, len(data)):\n",
    "        X.append(data[i - window : i, 0])   # 过去 window 天\n",
    "        y.append(data[i, 0])                 # 第 window+1 天\n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "# 构造训练样本\n",
    "X_train, y_train = create_sequences(train_scaled, WINDOW)\n",
    "\n",
    "# 构造测试样本\n",
    "# 注意：测试集的前 WINDOW 天需要借用训练集末尾的数据\n",
    "# 否则第一个测试样本凑不够30天\n",
    "test_full_scaled = np.concatenate([train_scaled[-WINDOW:], test_scaled], axis=0)\n",
    "X_test,  y_test  = create_sequences(test_full_scaled, WINDOW)\n",
    "\n",
    "# 调整维度为 LSTM 需要的 (样本数, 时间步, 特征数)\n",
    "X_train = X_train.reshape(X_train.shape[0], X_train.shape[1], 1)\n",
    "X_test  = X_test.reshape(X_test.shape[0],  X_test.shape[1],  1)\n",
    "\n",
    "print(f\"\\n  窗口大小：{WINDOW} 天\")\n",
    "print(f\"\\n  训练集样本：\")\n",
    "print(f\"    X_train shape = {X_train.shape}  (样本数, 时间步, 特征数)\")\n",
    "print(f\"    y_train shape = {y_train.shape}\")\n",
    "print(f\"\\n  测试集样本：\")\n",
    "print(f\"    X_test  shape = {X_test.shape}\")\n",
    "print(f\"    y_test  shape = {y_test.shape}\")\n",
    "print(f\"\\n  ✅ 数据准备完成，可进入模型构建阶段\")\n"

    "# ==================================================\n",
    "# LSTM 第6步：测试集滚动预测\n",
    "# ==================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# ---------- 滚动预测 ----------\n",
    "# 用训练集最后 lookback 天作为初始窗口\n",
    "history = list(train_scaled[-WINDOW:])   # shape: (lookback,)\n",
    "\n",
    "predictions_scaled = []\n",
    "\n",
    "for i in range(len(test)):\n",
    "    # 取最近 lookback 天 → reshape 成 (1, lookback, 1)\n",
    "    x_input = np.array(history[-WINDOW:]).reshape(1, WINDOW, 1)\n",
    "    \n",
    "    # 预测\n",
    "    y_pred_scaled = final_model.predict(x_input, verbose=0)[0][0]\n",
    "    predictions_scaled.append(y_pred_scaled)\n",
    "    \n",
    "    # 窗口滑动：加入真实值（Walk-Forward）\n",
    "    history.append(test_scaled[i])\n",
    "\n",
    "# ---------- 反标准化 ----------\n",
    "predictions = scaler.inverse_transform(\n",
    "    np.array(predictions_scaled).reshape(-1, 1)\n",
    ").flatten()\n",
    "\n",
    "actuals = scaler.inverse_transform(\n",
    "    test_scaled.reshape(-1, 1)\n",
    ").flatten()\n",
    "\n",
    "# ---------- 评估指标 ----------\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_error, r2_score\n",
    "mae  = np.mean(np.abs(actuals - predictions))\n",
    "rmse = np.sqrt(np.mean((actuals - predictions) ** 2))\n",
    "mape = np.mean(np.abs((actuals - predictions) / actuals)) * 100\n",
    "r2   = r2_score(actuals, predictions)\n",
    "\n",
    "print(\"========== LSTM 测试集滚动预测结果 ==========\")\n",
    "print(f\"  MAE  : {mae:.4f} °C\")\n",
    "print(f\"  RMSE : {rmse:.4f} °C\")\n",
    "print(f\"  MAPE : {mape:.4f} %\")\n",
    "print(f\"  R² = {r2:.4f}\") \n",
    "print(\"=\" * 45)\n",
    "\n",
    "# ---------- 画图 ----------\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 8))\n",
    "\n",
    "# --- 上图：真实值 vs 预测值 ---\n",
    "ax1 = axes[0]\n",
    "ax1.plot(test.index, actuals,     label='真实值',    color='black',    linewidth=1.5)\n",
    "ax1.plot(test.index, predictions, label='LSTM预测值', color='steelblue', linewidth=1.5,\n",
    "         linestyle='--')\n",
    "ax1.set_title(f'LSTM 测试集滚动预测  MAE={mae:.2f}°C  RMSE={rmse:.2f}°C  MAPE={mape:.2f}%',\n",
    "              fontsize=12)\n",
    "ax1.set_xlabel('日期')\n",
    "ax1.set_ylabel('温度 (°C)')\n",
    "ax1.legend()\n",
    "ax1.grid(True, alpha=0.3)\n",
    "\n",
    "# --- 下图：逐日误差柱状图 ---\n",
    "ax2 = axes[1]\n",
    "errors = actuals - predictions\n",
    "colors = ['red' if e < 0 else 'steelblue' for e in errors]\n",
    "ax2.bar(test.index, errors, color=colors, alpha=0.7, width=0.8)\n",
    "ax2.axhline(0,    color='black',     linewidth=0.8)\n",
    "ax2.axhline( mae, color='darkorange', linestyle='--',\n",
    "             linewidth=1.2, label=f'+MAE={mae:.2f}°C')\n",
    "ax2.axhline(-mae, color='darkorange', linestyle='--',\n",
    "             linewidth=1.2, label=f'-MAE={mae:.2f}°C')\n",
    "ax2.set_title('逐日预测误差（正=预测偏低，负=预测偏高）', fontsize=12)\n",
    "ax2.set_xlabel('日期')\n",
    "ax2.set_ylabel('误差 (°C)')\n",
    "ax2.legend()\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.suptitle('LSTM 测试集滚动预测诊断', fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.savefig('lstm_step6_rolling_forecast.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"\\n图已保存：lstm_step6_rolling_forecast.png\\n\")\n",
    "\n",
    "# ---------- 保存预测结果表 ----------\n",
    "result_df = pd.DataFrame({\n",

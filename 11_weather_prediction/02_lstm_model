    "!pip install optuna scikit-learn\n",
    "!pip install \"optuna-integration[tfkeras]\"\n",
    "# ==================================================\n",
    "# LSTM 第二步：基于 Optuna 优化 + 最优模型最终训练与可视化\n",
    "# ==================================================\n",
    "print(\"=\" * 60)\n",
    "print(\"  LSTM 第二步：基于 Optuna 优化 + 最优模型最终训练与可视化\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "import tensorflow as tf\n",
    "from tensorflow.keras.models import Sequential\n",
    "from tensorflow.keras.layers import LSTM, Dropout, Dense\n",
    "from tensorflow.keras.callbacks import EarlyStopping\n",
    "import optuna\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. 固定随机种子，保证优化实验可复现\n",
    "tf.random.set_seed(42)\n",
    "np.random.seed(42)\n",
    "\n",
    "# 2. 从已有训练集 X_train 中，划出最后 20% 作为验证集\n",
    "val_ratio = 0.2\n",
    "val_size  = int(len(X_train) * val_ratio)\n",
    "\n",
    "X_val = X_train[-val_size:]\n",
    "y_val = y_train[-val_size:]\n",
    "X_tr  = X_train[:-val_size]\n",
    "y_tr  = y_train[:-val_size]\n",
    "\n",
    "print(f\"  [数据就绪] 调参训练集样本数：{len(X_tr)} | 调参验证集样本数：{len(X_val)}\\n\")\n",
    "\n",
    "# 3. 设置 Optuna 的日志级别，避免大量单轮迭代文本刷屏\n",
    "optuna.logging.set_verbosity(optuna.logging.WARNING)\n",
    "\n",
    "# 4. 定义 Optuna 优化的核心目标函数\n",
    "def objective(trial):\n",
    "    # 【参数空间定义】\n",
    "    lstm_units = trial.suggest_int(\"lstm_units\", 16, 128, step=16)\n",
    "    dropout_rate = trial.suggest_float(\"dropout_rate\", 0.0, 0.5, step=0.1)\n",
    "    learning_rate = trial.suggest_float(\"learning_rate\", 1e-4, 1e-2, log=True)\n",
    "    batch_size = trial.suggest_categorical(\"batch_size\", [16, 32, 64])\n",
    "\n",
    "    # 【模型构建】\n",
    "    model = Sequential([\n",
    "        LSTM(lstm_units, input_shape=(WINDOW, 1), return_sequences=False),\n",
    "        Dropout(dropout_rate),\n",
    "        Dense(1)\n",
    "    ])\n",
    "    \n",
    "    optimizer = tf.keras.optimizers.Adam(learning_rate=learning_rate)\n",
    "    model.compile(optimizer=optimizer, loss='mse')\n",
    "    \n",
    "    # 【双重监控机制】\n",
    "    early_stop = EarlyStopping(monitor='val_loss', patience=10, restore_best_weights=True, verbose=0)\n",
    "    pruning_callback = optuna.integration.TFKerasPruningCallback(trial, \"val_loss\")\n",
    "    \n",
    "    # 【模型训练】\n",
    "    history = model.fit(\n",
    "        X_tr, y_tr,\n",
    "        epochs=100,\n",
    "        batch_size=batch_size,\n",
    "        validation_data=(X_val, y_val),\n",
    "        callbacks=[early_stop, pruning_callback],\n",
    "        verbose=0\n",
    "    )\n",
    "    return min(history.history['val_loss'])\n",
    "\n",
    "# 5. 启动 Optuna 寻优引擎\n",
    "print(\">>> 开始超参数智能搜索（计划尝试 30 种不同的参数组合）...\")\n",
    "print(\"    整个过程包含剪枝策略，请耐心等待...\")\n",
    "\n",
    "study = optuna.create_study(direction=\"minimize\", pruner=optuna.pruners.MedianPruner())\n",
    "study.optimize(objective, n_trials=30)\n",
    "\n",
    "# 6. 打印最终的最优结果\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"  ★ 超参数优化搜索成功完成 ★\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"  最优验证集复盘 Loss (MSE): {study.best_value:.6f}\")\n",
    "print(\"  最优超参数组合推荐 (Best Parameters):\")\n",
    "for key, value in study.best_params.items():\n",
    "    if key == \"learning_rate\":\n",
    "        print(f\"    - {key}: {value:.6f}\")\n",
    "    else:\n",
    "        print(f\"    - {key}: {value}\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "\n",
    "# ==================================================\n",
    "# 7. 【新增部分】提取最优参数，进行最终模型训练并绘制 Loss 曲线\n",
    "# ==================================================\n",
    "print(\"\\n>>> 正在使用 Optuna 选出的黄金参数重新训练最终模型...\")\n",
    "\n",
    "# 提取最优超参数\n",
    "best_units = study.best_params['lstm_units']\n",
    "best_dropout = study.best_params['dropout_rate']\n",
    "best_lr = study.best_params['learning_rate']\n",
    "best_batch = study.best_params['batch_size']\n",
    "\n",
    "# 用最优参数重新构建网络架构\n",
    "final_model = Sequential([\n",
    "    LSTM(best_units, input_shape=(WINDOW, 1), return_sequences=False),\n",
    "    Dropout(best_dropout),\n",
    "    Dense(1)\n",
    "])\n",
    "\n",
    "final_optimizer = tf.keras.optimizers.Adam(learning_rate=best_lr)\n",
    "final_model.compile(optimizer=final_optimizer, loss='mse')\n",
    "\n",
    "# 最终模型的早停机制（既然是最优参数，为了训练更充分，可以将恢复后的早停耐心值调大到 15）\n",
    "final_early_stop = EarlyStopping(\n",
    "    monitor='val_loss',\n",
    "    patience=15,\n",
    "    restore_best_weights=True,\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "# 启动最终训练（此时可以设置 verbose=1 观察收敛进度）\n",
    "final_history = final_model.fit(\n",
    "    X_tr, y_tr,\n",
    "    epochs=200,                    # 最优模型允许跑满 200 轮（配合早停）\n",
    "    batch_size=best_batch,\n",
    "    validation_data=(X_val, y_val),\n",
    "    callbacks=[final_early_stop],\n",
    "    verbose=1\n",
    ")\n",
    "\n",
    "# ---------- 训练过程 Loss 曲线可视化 ----------\n",
    "fig, ax = plt.subplots(figsize=(10, 4.5))\n",
    "\n",
    "# 绘制训练集和验证集的 Loss\n",
    "ax.plot(final_history.history['loss'],     label='Train Loss (训练集)', color='steelblue', linewidth=1.5)\n",
    "ax.plot(final_history.history['val_loss'], label='Val Loss (验证集)',   color='darkorange', linewidth=1.5, linestyle='--')\n",
    "\n",
    "# 自动定位实际停止和最优的 Epoch\n",
    "best_epoch = np.argmin(final_history.history['val_loss']) + 1\n",
    "ax.axvline(x=best_epoch - 1, color='red', linestyle=':', linewidth=1.5,\n",
    "           label=f'Best Epoch = {best_epoch}')\n",
    "\n",
    "# 美化图表\n",
    "ax.set_title(f'Optuna 优化后最终 LSTM 模型训练过程 - Loss 曲线\\n(Units={best_units}, LR={best_lr:.5f}, Batch={best_batch})', fontsize=12)\n",
    "ax.set_xlabel('Epoch (训练轮次)')\n",
    "ax.set_ylabel('MSE Loss (均方误差)')\n",
    "ax.legend(loc='upper right')\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('lstm_optuna_best_loss.png', dpi=150, bbox_inches='tight') # 顺便保存图片到本地用于论文\n",
    "plt.show()\n",
    "\n",
    "print(f\"\\n  图已保存：lstm_optuna_best_loss.png\")\n",
    "print(f\"  实际训练轮次：{len(final_history.history['loss'])} epochs\")\n",
    "print(f\"  最优 Epoch：{best_epoch}\")\n",
    "print(f\"  最优验证集 Loss：{min(final_history.history['val_loss']):.6f}\")\n",
    "print(f\"\\n✅ 最优 LSTM 模型训练并保存完毕，后续预测直接使用 `final_model` 对象即可！\")"
   ]
  },

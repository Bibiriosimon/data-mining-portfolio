    "from tensorflow.keras.callbacks import EarlyStopping\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. 启动 Optuna 寻优引擎（尝试 30 种组合）\n",
    "optuna.logging.set_verbosity(optuna.logging.WARNING)\n",
    "study = optuna.create_study(direction=\"minimize\", pruner=optuna.pruners.MedianPruner())\n",
    "study.optimize(objective, n_trials=30)\n",
    "\n",
    "print(\"最优超参数:\", study.best_params)\n",
    "\n",
    "# 2. 提取出最强参数，重构你的最终黄金模型\n",
    "final_tcn_model = Sequential([\n",
    "    TCN(\n",
    "        input_shape=(WINDOW, 1),\n",
    "        nb_filters=study.best_params['nb_filters'],\n",
    "        kernel_size=study.best_params['kernel_size'],\n",
    "        nb_stacks=1,\n",
    "        dilations=[1, 2, 4, 8],\n",
    "        padding='causal',\n",
    "        use_skip_connections=True,\n",
    "        dropout_rate=study.best_params['dropout_rate'],\n",
    "        return_sequences=False\n",
    "    ),\n",
    "    Dense(1)\n",
    "])\n",
    "\n",
    "final_tcn_model.compile(optimizer=Adam(learning_rate=study.best_params['learning_rate']), loss='mse')\n",
    "\n",
    "# 3. 最终训练（配合早停，patience=15）\n",
    "early_stop = EarlyStopping(monitor='val_loss', patience=15, restore_best_weights=True)\n",
    "\n",
    "history = final_tcn_model.fit(\n",
    "    X_tr, y_tr,\n",
    "    epochs=100,\n",
    "    batch_size=study.best_params['batch_size'],\n",
    "    validation_data=(X_val, y_val),\n",
    "    callbacks=[early_stop],\n",
    "    verbose=1\n",
    ")\n"
   ]

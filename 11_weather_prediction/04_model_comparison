    "# ============================================================\n",
    "# 实验A：单步预测整体对比\n",
    "# ============================================================\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib\n",
    "import matplotlib.font_manager as fm\n",
    "import matplotlib.dates as mdates\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
    "matplotlib.rc('font', family='Heiti TC')\n",
    "matplotlib.rcParams['font.sans-serif'] = ['Heiti TC']\n",
    "matplotlib.rcParams['axes.unicode_minus'] = False\n",
    "\n",
    "# ---------- 1. 统一列名----------\n",
    "TRUE_COL = '真实值'\n",
    "PRED_COL = '预测值'\n",
    "\n",
    "y_true_arima = arima_df[TRUE_COL].values\n",
    "y_pred_arima = arima_df[PRED_COL].values\n",
    "\n",
    "y_true_lstm  = lstm_df[TRUE_COL].values\n",
    "y_pred_lstm  = lstm_df[PRED_COL].values\n",
    "\n",
    "y_true_tcn   = tcn_df[TRUE_COL].values\n",
    "y_pred_tcn   = tcn_df[PRED_COL].values\n",
    "\n",
    "# ---------- 2. 定义指标计算函数 ----------\n",
    "def calc_metrics(y_true, y_pred, model_name):\n",
    "    mae  = mean_absolute_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mean_squared_error(y_true, y_pred))\n",
    "    mape = np.mean(np.abs((y_true - y_pred) / y_true)) * 100\n",
    "    r2   = r2_score(y_true, y_pred)\n",
    "    return {\n",
    "        '模型':  model_name,\n",
    "        'MAE':   round(mae,  4),\n",
    "        'RMSE':  round(rmse, 4),\n",
    "        'MAPE(%)': round(mape, 4),\n",
    "        'R²':    round(r2,   4)\n",
    "    }\n",
    "\n",
    "# ---------- 3. 计算三个模型指标 ----------\n",
    "metrics_list = [\n",
    "    calc_metrics(y_true_arima, y_pred_arima, 'ARIMA'),\n",
    "    calc_metrics(y_true_lstm,  y_pred_lstm,  'LSTM'),\n",
    "    calc_metrics(y_true_tcn,   y_pred_tcn,   'TCN'),\n",
    "]\n",
    "\n",
    "# ---------- 4. 汇总表格 ----------\n",
    "metrics_df = pd.DataFrame(metrics_list).set_index('模型')\n",
    "\n",
    "print(\"=== 实验A：单步预测指标汇总 ===\")\n",
    "print(metrics_df.to_string())\n",
    "\n",
    "# ---------- 5. 折线对比图（主图 + 局部放大） ----------\n",
    "fig = plt.figure(figsize=(15, 10))\n",
    "\n",
    "# 布局：上方主图，下方两个放大子图\n",
    "gs = fig.add_gridspec(2, 2, height_ratios=[1.8, 1], hspace=0.45, wspace=0.3)\n",
    "\n",
    "ax_main  = fig.add_subplot(gs[0, :])   # 上方横跨两列的主图\n",
    "ax_zoom1 = fig.add_subplot(gs[1, 0])   # 左下：3-4月春季转换期\n",
    "ax_zoom2 = fig.add_subplot(gs[1, 1])   # 右下：7月高温峰值期\n",
    "\n",
    "dates = lstm_df.index\n",
    "\n",
    "# ── 颜色 / 线型统一配置 ──────────────────────────────────────────────\n",
    "STYLE = {\n",
    "    '真实值':      dict(color='black',   linewidth=1.7, linestyle='-',  alpha=1.0,  zorder=5),\n",
    "    'ARIMA预测值': dict(color='#1f77b4', linewidth=1.2, linestyle='--', alpha=0.85, zorder=4),\n",
    "    'LSTM预测值':  dict(color='#ff7f0e', linewidth=1.2, linestyle='-.', alpha=0.85, zorder=3),\n",
    "    'TCN预测值':   dict(color='#2ca02c', linewidth=1.2, linestyle='--',  alpha=0.85, zorder=2),\n",
    "}\n",
    "\n",
    "# ── 放大时间段定义 ────────────────────────────────────────────────────\n",
    "ZOOM_RANGES = [\n",
    "    ('2024-03-01', '2024-04-30', '局部放大 A：春季转换期 (3-4月)'),\n",
    "    ('2024-07-01', '2024-07-31', '局部放大 B：高温峰值期 (7月)'),\n",
    "]\n",
    "\n",
    "# ── 绘图函数（主图和子图复用） ────────────────────────────────────────\n",
    "def draw_lines(ax, mask=None):\n",
    "    idx = mask if mask is not None else slice(None)\n",

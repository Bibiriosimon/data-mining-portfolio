    "    ax.plot(d, y_pred_lstm[idx],  label='LSTM预测值',  **STYLE['LSTM预测值'])\n",
    "    ax.plot(d, y_pred_tcn[idx],   label='TCN预测值',   **STYLE['TCN预测值'])\n",
    "\n",
    "# ── 主图 ──────────────────────────────────────────────────────────────\n",
    "draw_lines(ax_main)\n",
    "\n",
    "# 在主图上用浅色矩形标注放大区域\n",

    "# ── 两个放大子图 ──────────────────────────────────────────────────────\n",
    "for ax_z, (start, end, title) in zip([ax_zoom1, ax_zoom2], ZOOM_RANGES):\n",
    "    mask = (dates >= pd.Timestamp(start)) & (dates <= pd.Timestamp(end))\n",
    "    draw_lines(ax_z, mask)\n",
    "\n",
    "    ax_z.xaxis.set_major_formatter(mdates.DateFormatter('%m-%d'))\n",
    "    ax_z.xaxis.set_major_locator(mdates.WeekdayLocator(interval=2))\n",
    "    plt.setp(ax_z.xaxis.get_majorticklabels(), rotation=30, ha='right', fontsize=8)\n",
    "    ax_z.set_title(title, fontsize=9, pad=6)\n",
    "    ax_z.set_ylabel('气温 (°C)', fontsize=9)\n",
    "    ax_z.grid(True, linestyle=':', alpha=0.4)\n",
    "    ax_z.spines['top'].set_visible(False)\n",
    "    ax_z.spines['right'].set_visible(False)\n",
    "\n",
    "# ── 保存 ─────────────────────────────────────────────────────────────\n",
    "plt.savefig('实验A_单步预测对比.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"对比折线图已保存 ✅\")\n",
    "\n",
    "\n",
    "\n",
    "# ---------- 6. 指标柱状图 ----------\n",
    "fig, axes = plt.subplots(1, 4, figsize=(14, 4))\n",
    "metrics_plot = ['MAE', 'RMSE', 'MAPE(%)', 'R²']\n",

    "def lstm_multi_step(model, scaler, full_series, window_size, max_steps):\n",
    "    \"\"\"\n",
    "    递归预测：把上一步预测值拼入窗口，再预测下一步\n",
    "    返回 dict：{step: [预测值列表]}\n",
    "    \"\"\"\n",
    "    series_scaled = scaler.transform(full_series.reshape(-1, 1)).flatten()\n",
    "\n",
    "    step_preds = {s: [] for s in range(1, max_steps + 1)}\n",
    "    step_trues = {s: [] for s in range(1, max_steps + 1)}\n",
    "\n",
    "    total   = len(series_scaled)\n",
    "    n_rolls = total - window_size - max_steps + 1\n",
    "\n",
    "    print(f\"LSTM 滚动预测次数: {n_rolls}\")\n",
    "\n",
    "    for i in range(n_rolls):\n",
    "        window = series_scaled[i: i + window_size].copy()\n",
    "\n",
    "        for s in range(1, max_steps + 1):\n",
    "            x_input = window[-window_size:].reshape(1, window_size, 1)\n",
    "            pred_scaled = model.predict(x_input, verbose=0)[0][0]\n",
    "\n",
    "            # 反归一化\n",
    "            pred_val = scaler.inverse_transform([[pred_scaled]])[0][0]\n",
    "            true_val = full_series[i + window_size + s - 1]\n",
    "\n",
    "            step_preds[s].append(pred_val)\n",
    "            step_trues[s].append(true_val)\n",
    "\n",
    "            # 把预测值拼入窗口，用于下一步\n",
    "            window = np.append(window, pred_scaled)\n",
    "\n",
    "    return step_preds, step_trues\n",
    "\n",
    "print(\"LSTM 多步预测函数定义完毕 ✅\")\n"

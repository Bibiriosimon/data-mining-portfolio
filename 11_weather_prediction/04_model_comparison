    "# ============================================================\n",
    "# 实验B：极端气温子集对比\n",
    "# ============================================================\n",
    "matplotlib.rc('font', family='Heiti TC')\n",
    "matplotlib.rcParams['font.sans-serif'] = ['Heiti TC']\n",
    "matplotlib.rcParams['axes.unicode_minus'] = False\n",
    "# ---------- 1. 定义极端气温阈值----------\n",
    "y_true = lstm_df[TRUE_COL].values   # 三个模型真实值一样，用LSTM那列即可\n",
    "\n",
    "high_threshold = np.percentile(y_true, 90)   # 前10% 高温\n",
    "low_threshold  = np.percentile(y_true, 10)   # 后10% 低温\n",
    "\n",
    "print(\"=== 极端气温阈值 ===\")\n",
    "print(f\"高温阈值（前10%）: ≥ {high_threshold:.2f} °C\")\n",
    "print(f\"低温阈值（后10%）: ≤ {low_threshold:.2f} °C\")\n",
    "\n",
    "# ---------- 2. 抠出极端天的索引 ----------\n",
    "high_idx = np.where(y_true >= high_threshold)[0]\n",
    "low_idx  = np.where(y_true <= low_threshold)[0]\n",
    "\n",
    "print(f\"\\n高温天数: {len(high_idx)} 天\")\n",
    "print(f\"低温天数: {len(low_idx)} 天\")\n",
    "\n",
    "# ---------- 3. 定义子集指标计算函数 ----------\n",
    "def calc_subset_metrics(y_true_full, y_pred_full, idx, model_name):\n",
    "    y_t = y_true_full[idx]\n",
    "    y_p = y_pred_full[idx]\n",
    "    mae  = mean_absolute_error(y_t, y_p)\n",
    "    rmse = np.sqrt(mean_squared_error(y_t, y_p))\n",
    "    mape = np.mean(np.abs((y_t - y_p) / y_t)) * 100\n",
    "    return {\n",
    "        '模型':    model_name,\n",
    "        'MAE':     round(mae,  4),\n",
    "        'RMSE':    round(rmse, 4),\n",
    "        'MAPE(%)': round(mape, 4),\n",
    "    }\n",
    "\n",
    "# ---------- 4. 高温子集指标 ----------\n",
    "high_metrics = [\n",
    "    calc_subset_metrics(y_true_arima, y_pred_arima, high_idx, 'ARIMA'),\n",
    "    calc_subset_metrics(y_true_lstm,  y_pred_lstm,  high_idx, 'LSTM'),\n",
    "    calc_subset_metrics(y_true_tcn,   y_pred_tcn,   high_idx, 'TCN'),\n",
    "]\n",
    "high_df = pd.DataFrame(high_metrics).set_index('模型')\n",
    "\n",
    "# ---------- 5. 低温子集指标 ----------\n",
    "low_metrics = [\n",
    "    calc_subset_metrics(y_true_arima, y_pred_arima, low_idx, 'ARIMA'),\n",
    "    calc_subset_metrics(y_true_lstm,  y_pred_lstm,  low_idx, 'LSTM'),\n",
    "    calc_subset_metrics(y_true_tcn,   y_pred_tcn,   low_idx, 'TCN'),\n",
    "]\n",
    "low_df = pd.DataFrame(low_metrics).set_index('模型')\n",
    "\n",
    "print(\"\\n=== 高温子集指标（前10%）===\")\n",
    "print(high_df.to_string())\n",
